@model ServiceRequestCreateViewModel
@{
    ViewData["Title"] = "New Service Request";
}
<h2>New Service Request</h2>
<form asp-action="Create" method="post" style="max-width:650px" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract</label>
        <select asp-for="ContractId" asp-items="Model.Contracts" class="form-select">
            <option value="">-- Select Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CostUsd" class="form-label">Cost (USD $)</label>
        <input asp-for="CostUsd" id="costUsd" type="number" step="0.01" min="0" class="form-control" />
        <span asp-validation-for="CostUsd" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Current USD → ZAR Rate</label>
        <input type="text" id="rateDisplay" class="form-control" readonly
               value="@Model.ExchangeRate.ToString("N4")" />
        <input type="hidden" id="exchangeRate" name="ExchangeRate" value="@Model.ExchangeRate" />
    </div>

    <div class="mb-3">
        <label class="form-label">Estimated Cost (ZAR R)</label>
        <input type="text" id="costZarDisplay" class="form-control bg-light" readonly value="R 0.00" />
        <input type="hidden" id="costZar" name="CostZar" value="0" />
    </div>

    <div class="mb-3">
        <label class="form-label">Status</label>
        <input type="text" class="form-control bg-light" readonly value="Pending" />
        <input type="hidden" asp-for="Status" value="0" />
        <small class="text-muted">Status is set to Pending and cannot be changed on creation.</small>
    </div>

    <button type="submit" class="btn btn-primary">Create Request</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <script>
        const rate = parseFloat(document.getElementById('exchangeRate').value) || 0;

        document.getElementById('costUsd').addEventListener('input', function () {
            const usd = parseFloat(this.value) || 0;
            const zar = (usd * rate).toFixed(2);
            document.getElementById('costZarDisplay').value = 'R ' + parseFloat(zar).toLocaleString('en-ZA', {minimumFractionDigits: 2});
            document.getElementById('costZar').value = zar;
        });
    </script>
}