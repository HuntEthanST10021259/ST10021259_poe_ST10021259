@model Contract
@{
    ViewData["Title"] = "Edit Contract";
}
<h2>Edit Contract</h2>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" style="max-width:650px">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="SignedAgreementPath" />
    <input type="hidden" asp-for="SignedAgreementFileName" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label asp-for="ServiceLevel" class="form-label"></label>
        <input asp-for="ServiceLevel" class="form-control" />
    </div>
    <div class="row">
        <div class="col mb-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>
        <div class="col mb-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()" class="form-select"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Signed Agreement</label>
        @if (Model.SignedAgreementPath != null)
        {
            <div class="mb-2">
                <span class="text-success">✓ File on record: @Model.SignedAgreementFileName</span>
                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-2">Download</a>
            </div>
        }
        <input type="file" name="signedAgreement" accept=".pdf" class="form-control" />
        <small class="text-muted">Upload a new PDF to replace the existing one.</small>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>