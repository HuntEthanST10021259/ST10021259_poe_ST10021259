@{
    ViewData["Title"] = "Dashboard";
}
<h2 class="mb-4">Dashboard</h2>
<div class="row g-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Clients</h5>
                <h2>@ViewBag.TotalClients</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Total Contracts</h5>
                <h2>@ViewBag.TotalContracts</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Active Contracts</h5>
                <h2>@ViewBag.ActiveContracts</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Service Requests</h5>
                <h2>@ViewBag.TotalRequests</h2>
            </div>
        </div>
    </div>
</div>