@model IEnumerable<Client>
@{
    ViewData["Title"] = "Clients";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<div class="d-flex justify-content-between mb-3">
    <h2>Clients</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Client</a>
</div>
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr><th>Name</th><th>Contact Details</th><th>Region</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.ContactDetails</td>
                <td>@c.Region</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>